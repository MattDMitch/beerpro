# Beer Pro — gitignore

# WiFi credentials — never commit, written at runtime by wifi_manager.py
wifi_credentials.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Runtime backup dir (created by update_manager.py at runtime)
backups/

# Release zip artifacts (hosted as GitHub Release assets, not in repo)
*.zip
*.zip.manifest

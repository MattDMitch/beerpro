# Beer Pro — pi-gen build configuration
# Reference: https://github.com/RPi-Distro/pi-gen#config
#
# Target: Raspberry Pi OS Bookworm 64-bit (arm64)
# Built from tag: 2025-05-13-raspios-bookworm-arm64
# Requires: Docker Desktop on Apple Silicon (M1/M2/M3) or any Linux/amd64 host

IMG_NAME="beerpro-v1.0-pi3bplus"
RELEASE="bookworm"
TARGET_HOSTNAME="beerpro"

FIRST_USER_NAME="pi"
FIRST_USER_PASS="beerpro2024"
DISABLE_FIRST_BOOT_USER_RENAME=1

# SSH disabled — users have no reason to SSH into a beer pong scoreboard
ENABLE_SSH=0

# Locale / timezone
LOCALE_DEFAULT="en_US.UTF-8"
TIMEZONE_DEFAULT="America/New_York"
KEYBOARD_KEYMAP="us"
KEYBOARD_LAYOUT="English (US)"

# Skip the desktop stages — we only need Lite + our custom stageB
SKIP_STAGE_FILES=0

# Image compression
DEPLOY_COMPRESSION=xz

# Container name for Docker builds
CONTAINER_NAME="beerpro_pigen_work"
